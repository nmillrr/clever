{
  "manifest_version": 3,
  "name": "Clever",
  "version": "1.0.0",
  "description": "Access academic resources through your university's library subscriptions",
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Clever - University Library Access"
  },
  "icons": {
    "16": "assets/clever-logo.png",
    "48": "assets/clever-logo.png",
    "128": "assets/clever-logo.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["databases/*.csv", "assets/*.png"],
      "matches": ["<all_urls>"]
    }
  ]
}